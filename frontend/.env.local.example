# Base URL of the FastAPI backend (see ../backend). No trailing slash.
# The backend is commonly run on 8000 or 8001 depending on how it was
# started (see backend/main.py's __main__ block vs. manual uvicorn
# invocations) — check which port your instance is actually listening on
# (curl http://127.0.0.1:8000/health or :8001/health) and set it here.
#
# Copy this file to .env.local and adjust if needed:
#   cp .env.local.example .env.local
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001

# Supabase project used for authentication (email/password). Find both
# values in your Supabase project dashboard under Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
