# Groq API key — required for query rewriting and answer generation.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Postgres connection string (Supabase-hosted recommended) — used to persist
# ingested-document records, conversation history, and query logs.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase project URL and anon (public) key — used to verify end-user auth
# tokens on incoming requests. Find both in your Supabase dashboard under
# Settings > API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
